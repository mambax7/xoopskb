#!/bin/bash
#
# XOOPS Knowledge Base - Pre-commit Hook
# Validates filenames before allowing commits
#
# Installation:
#   cp .github/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or run: .github/hooks/install-hooks.sh

set -e

echo "🔍 Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

ERRORS=0

# ============================================================
# Check 1: Files with spaces in names
# ============================================================
echo -n "  Checking for files with spaces... "

# Get staged files with spaces
FILES_WITH_SPACES=$(git diff --cached --name-only --diff-filter=ACM | grep " " || true)

if [ -n "$FILES_WITH_SPACES" ]; then
    echo -e "${RED}FAILED${NC}"
    echo ""
    echo -e "${RED}❌ ERROR: The following staged files have spaces in their names:${NC}"
    echo "$FILES_WITH_SPACES" | while read -r file; do
        echo "    - $file"
    done
    echo ""
    echo -e "${YELLOW}Spaces in filenames cause issues with:${NC}"
    echo "    - MkDocs documentation builds"
    echo "    - URL generation"
    echo "    - Cross-platform compatibility"
    echo ""
    echo -e "${YELLOW}To fix, rename files using hyphens instead of spaces:${NC}"
    echo "    Example: 'My File.md' → 'My-File.md'"
    echo ""
    echo "    Quick fix command:"
    echo "    git reset HEAD <file>"
    echo "    mv \"<file with spaces>\" \"<file-with-hyphens>\""
    echo "    git add \"<file-with-hyphens>\""
    echo ""
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}OK${NC}"
fi

# ============================================================
# Check 2: Wikilinks with spaces (in markdown files)
# ============================================================
echo -n "  Checking for wikilinks with spaces... "

# Get staged markdown files
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep "\.md$" || true)

WIKILINK_ISSUES=""
if [ -n "$STAGED_MD" ]; then
    for file in $STAGED_MD; do
        if [ -f "$file" ]; then
            # Check for wikilinks with spaces: [[Something With Spaces]]
            # But allow [[link|display text]] format
            ISSUES=$(grep -n '\[\[[^]|]*[[:space:]][^]|]*\]\]' "$file" 2>/dev/null | head -5 || true)
            if [ -n "$ISSUES" ]; then
                WIKILINK_ISSUES="${WIKILINK_ISSUES}\n  ${file}:\n${ISSUES}"
            fi
        fi
    done
fi

if [ -n "$WIKILINK_ISSUES" ]; then
    echo -e "${YELLOW}WARNING${NC}"
    echo ""
    echo -e "${YELLOW}⚠️  Found wikilinks with spaces (consider using hyphens):${NC}"
    echo -e "$WIKILINK_ISSUES"
    echo ""
    echo "    Example: [[Getting Started]] → [[Getting-Started]]"
    echo ""
    # This is a warning, not an error
else
    echo -e "${GREEN}OK${NC}"
fi

# ============================================================
# Check 3: Very long filenames (>100 chars)
# ============================================================
echo -n "  Checking for very long filenames... "

LONG_FILES=$(git diff --cached --name-only --diff-filter=ACM | awk 'length > 100' || true)

if [ -n "$LONG_FILES" ]; then
    echo -e "${YELLOW}WARNING${NC}"
    echo ""
    echo -e "${YELLOW}⚠️  The following files have very long names (>100 chars):${NC}"
    echo "$LONG_FILES" | while read -r file; do
        echo "    - $file ($(echo -n "$file" | wc -c) chars)"
    done
    echo ""
    # This is a warning, not an error
else
    echo -e "${GREEN}OK${NC}"
fi

# ============================================================
# Summary
# ============================================================
echo ""
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}❌ Pre-commit check failed with $ERRORS error(s)${NC}"
    echo "Please fix the issues above and try again."
    echo ""
    echo "To bypass this check (not recommended):"
    echo "    git commit --no-verify"
    exit 1
else
    echo -e "${GREEN}✅ All pre-commit checks passed${NC}"
fi

exit 0
