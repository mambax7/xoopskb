  "XOOPS Entity": {
    "prefix": "xentity",
    "description": "Create a XOOPS 4.0 domain entity",
    "body": [
      "<?php",
      "",
      "declare(strict_types=1);",
      "",
      "namespace ${1:Module}\\\\Domain\\\\Entity;",
      "",
      "use ${1:Module}\\\\Domain\\\\ValueObject\\\\${2:Entity}Id;",
      "use ${1:Module}\\\\Domain\\\\ValueObject\\\\${2:Entity}Title;",
      "use ${1:Module}\\\\Domain\\\\ValueObject\\\\${2:Entity}Content;",
      "use ${1:Module}\\\\Domain\\\\ValueObject\\\\${2:Entity}Status;",
      "",
      "/**",
      " * ${2:Entity} - ${3:Description}.",
      " */",
      "final class ${2:Entity}",
      "{",
      "    private \\\\DateTimeImmutable \\$updatedAt;",
      "",
      "    private function __construct(",
      "        private readonly ${2:Entity}Id \\$id,",
      "        private readonly int \\$authorId,",
      "        private ${2:Entity}Title \\$title,",
      "        private ${2:Entity}Content \\$content,",
      "        private ${2:Entity}Status \\$status,",
      "        private readonly \\\\DateTimeImmutable \\$createdAt",
      "    ) {",
      "        \\$this->updatedAt = \\$createdAt;",
      "    }",
      "",
      "    public static function create(",
      "        int \\$authorId,",
      "        ${2:Entity}Title \\$title,",
      "        ${2:Entity}Content \\$content",
      "    ): self {",
      "        return new self(",
      "            id: ${2:Entity}Id::generate(),",
      "            authorId: \\$authorId,",
      "            title: \\$title,",
      "            content: \\$content,",
      "            status: ${2:Entity}Status::Draft,",
      "            createdAt: new \\\\DateTimeImmutable()",
      "        );",
      "    }",
      "",
      "    public static function reconstitute(",
      "        ${2:Entity}Id \\$id,",
      "        int \\$authorId,",
      "        ${2:Entity}Title \\$title,",
      "        ${2:Entity}Content \\$content,",
      "        ${2:Entity}Status \\$status,",
      "        \\\\DateTimeImmutable \\$createdAt,",
      "        \\\\DateTimeImmutable \\$updatedAt",
      "    ): self {",
      "        \\$entity = new self(\\$id, \\$authorId, \\$title, \\$content, \\$status, \\$createdAt);",
      "        \\$entity->updatedAt = \\$updatedAt;",
      "        return \\$entity;",
      "    }",
      "",
      "    public function getId(): ${2:Entity}Id { return \\$this->id; }",
      "    public function getAuthorId(): int { return \\$this->authorId; }",
      "    public function getTitle(): ${2:Entity}Title { return \\$this->title; }",
      "    public function getContent(): ${2:Entity}Content { return \\$this->content; }",
      "    public function getStatus(): ${2:Entity}Status { return \\$this->status; }",
      "    public function getCreatedAt(): \\\\DateTimeImmutable { return \\$this->createdAt; }",
      "    public function getUpdatedAt(): \\\\DateTimeImmutable { return \\$this->updatedAt; }",
      "",
      "    public function updateTitle(${2:Entity}Title \\$newTitle): void",
      "    {",
      "        if (!\\$this->title->equals(\\$newTitle)) {",
      "            \\$this->title = \\$newTitle;",
      "            \\$this->touch();",
      "        }",
      "    }",
      "",
      "    private function touch(): void",
      "    {",
      "        \\$this->updatedAt = new \\\\DateTimeImmutable();",
      "    }",
      "}",
      ""
    ]
  },

