  "XOOPS Status Enum": {
    "prefix": "xstatus",
    "description": "Create a XOOPS 4.0 status enum",
    "body": [
      "<?php",
      "",
      "declare(strict_types=1);",
      "",
      "namespace ${1:Module}\\\\Domain\\\\ValueObject;",
      "",
