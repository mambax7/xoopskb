  "XOOPS Value Object": {
    "prefix": "xvo",
    "description": "Create a XOOPS 4.0 value object",
    "body": [
      "<?php",
      "",
      "declare(strict_types=1);",
      "",
      "namespace ${1:Module}\\\\Domain\\\\ValueObject;",
      "",
      "use ${1:Module}\\\\Domain\\\\Exception\\\\Invalid${2:Name};",
      "",
      "/**",
      " * ${2:Name} - ${3:Description}.",
      " */",
      "final readonly class ${2:Name} implements \\\\Stringable, \\\\JsonSerializable",
      "{",
      "    private const int MIN_LENGTH = ${4:1};",
      "    private const int MAX_LENGTH = ${5:200};",
      "",
      "    private function __construct(",
      "        private string \\$value",
      "    ) {}",
      "",
      "    public static function create(string \\$value): self",
      "    {",
      "        \\$value = trim(\\$value);",
      "",
      "        if (mb_strlen(\\$value) < self::MIN_LENGTH) {",
      "            throw Invalid${2:Name}::tooShort(self::MIN_LENGTH);",
      "        }",
      "",
      "        if (mb_strlen(\\$value) > self::MAX_LENGTH) {",
      "            throw Invalid${2:Name}::tooLong(self::MAX_LENGTH);",
      "        }",
      "",
      "        return new self(\\$value);",
      "    }",
      "",
      "    public function toString(): string",
      "    {",
      "        return \\$this->value;",
      "    }",
      "",
      "    public function equals(self \\$other): bool",
      "    {",
      "        return \\$this->value === \\$other->value;",
      "    }",
      "",
      "    public function __toString(): string",
      "    {",
      "        return \\$this->value;",
      "    }",
      "",
      "    public function jsonSerialize(): string",
      "    {",
      "        return \\$this->value;",
      "    }",
      "}",
      ""
    ]
  },

