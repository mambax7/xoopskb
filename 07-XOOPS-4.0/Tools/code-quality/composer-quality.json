{
    "_comment": "Merge these dev dependencies into your module's composer.json",
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-strict-rules": "^1.5",
        "phpstan/phpstan-phpunit": "^1.3",
        "friendsofphp/php-cs-fixer": "^3.50",
        "vimeo/psalm": "^5.22",
        "psalm/plugin-phpunit": "^0.18",
        "infection/infection": "^0.27"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "analyse": "phpstan analyse",
        "psalm": "psalm",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "infection": "infection --threads=4",
        "quality": [
            "@cs-check",
            "@analyse",
            "@psalm"
        ],
        "ci": [
            "@cs-check",
            "@analyse",
            "@psalm",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit tests",
        "test-coverage": "Run tests with HTML coverage report",
        "analyse": "Run PHPStan static analysis",
        "psalm": "Run Psalm type checking",
        "cs-check": "Check code style without fixing",
        "cs-fix": "Fix code style issues",
        "infection": "Run mutation testing",
        "quality": "Run all quality checks (no tests)",
        "ci": "Run all checks including tests (for CI)"
    }
}
